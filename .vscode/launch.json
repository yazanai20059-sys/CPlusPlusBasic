{
   "version": "2.0.0",
   "tasks": [
       {
           "label": "C/C++: g++ build active file",
           "type": "shell",
           "command": "/usr/bin/g++", // Ruta del compilador g++
           "args": [
               "-g", // Genera informació per a la depuració
               "${file}",
               "-lsfml-graphics", "-lsfml-window", "-lsfml-system", // Biblioteques SFML
               "-o", "${fileDirname}/a.out" // Compilació a un executable anomenat 'a.out'
           ],
           "group": {
               "kind": "build",
               "isDefault": true
           },
           "problemMatcher": ["$gcc"],
           "detail": "Genera el programa executable"
       }
   ]
}